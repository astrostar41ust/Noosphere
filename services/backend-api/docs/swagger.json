{
    "swagger": "2.0",
    "info": {
        "description": "Core high-performance orchestration gateway for the Noosphere ecosystem.",
        "title": "Noosphere Backend API Engine",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/chat/message": {
            "post": {
                "description": "Validates incoming token data streams and persists user/assistant dialogue payloads.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "chat"
                ],
                "summary": "Send a conversation message",
                "parameters": [
                    {
                        "description": "Chat Message Structure Payload",
                        "name": "payload",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_modules_chat.SendMessageRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal_modules_chat.ChatMessageResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid JSON or schema validation error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal processing engine database exception",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_modules_chat.ChatMessageResponse": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "session_id": {
                    "type": "string"
                }
            }
        },
        "internal_modules_chat.SendMessageRequest": {
            "type": "object",
            "required": [
                "content",
                "role",
                "session_id"
            ],
            "properties": {
                "content": {
                    "type": "string",
                    "minLength": 1
                },
                "role": {
                    "type": "string",
                    "enum": [
                        "user",
                        "assistant",
                        "system"
                    ]
                },
                "session_id": {
                    "type": "string"
                }
            }
        }
    }
}